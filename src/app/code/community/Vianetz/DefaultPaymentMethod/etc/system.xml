<?xml version="1.0"?>
<config>
    <sections>
        <payment>
            <groups>
                <default_payment translate="label" module="sales">
                    <label>Default Payment</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>0</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <note translate="label">
                            <frontend_type>note</frontend_type>
                            <sort_order>0</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment><![CDATA[
                        <strong>Default Payment Method 2.1.0</strong><br />by <a href="https://www.vianetz.com?mtm_source=mage_backend&mtm_campaign=mage_extension_config&mtm_medium=dpm_config_link" target="_blank">vianetz >_ Magento Freelancer</a>
             ]]></comment>
                        </note>

                        <method translate="label">
                            <label>Method</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_payment_allowedmethods</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>0</show_in_store>
                            <can_be_empty>1</can_be_empty>
                        </method>
                        <label translate="label">
                            <label>Label Text</label>
                            <comment>Optional label text to show after the default payment method in the list (if there are multiple methods).</comment>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </label>
                    </fields>
                </default_payment>
            </groups>
        </payment>
    </sections>
</config>
